# ============================================================
# .dockerignore
# ------------------------------------------------------------
# docker build 時に context へ送るファイルから除外するパターン
# 役割:
#   1. ビルドコンテキスト転送時間を短縮 (.git / node_modules を除外)
#   2. 秘密情報をイメージに含めない (.env)
#   3. ビルド成果物がキャッシュを汚染しないようにする (dist, build)
# ============================================================

# ----------------------------------------
# Git
# ----------------------------------------
.git
.gitignore
.gitattributes
.github

# ----------------------------------------
# Node.js
# ----------------------------------------
**/node_modules
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ----------------------------------------
# ビルド成果物 (builder stage で再生成される)
# ----------------------------------------
backend/dist
frontend/dist
frontend/build
frontend/.vite
shared/*.js
shared/*.d.ts
shared/*.map

# ----------------------------------------
# 環境変数ファイル (秘密情報はイメージに含めない)
# .env.example は Dockerfile が参照する可能性を残して include
# ----------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# ----------------------------------------
# アップロード (本番では volume mount で永続化)
# ----------------------------------------
backend/uploads

# ----------------------------------------
# テスト関連
# ----------------------------------------
test/node_modules
coverage
.nyc_output

# ----------------------------------------
# IDE / エディタ
# ----------------------------------------
.vscode
.idea
*.swp
*.swo

# ----------------------------------------
# OS 生成ファイル
# ----------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------
# ドキュメント / ローカル設定
# ----------------------------------------
README.md
CLAUDE.md
docs
.claude

# ----------------------------------------
# Docker 関連 (compose ファイルはビルド時には不要)
# ----------------------------------------
docker-compose*.yml

# ----------------------------------------
# SSL 証明書 (起動時に volume mount される)
# ----------------------------------------
nginx/ssl

# ----------------------------------------
# Makefile (ビルド時には不要)
# ----------------------------------------
Makefile

# ----------------------------------------
# ログ
# ----------------------------------------
*.log
logs
