# ----------------------------------------------
# PostgreSQL データベース設定
# ----------------------------------------------
POSTGRES_USER=transcendence
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=transcendence_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ----------------------------------------------
# バックエンド設定（NestJS）
# ----------------------------------------------
# CSRFトークン署名キー（ランダムな文字列を設定）
# 生成方法: openssl rand -hex 32
CSRF_SECRET=csrf_secret_key_here

# JWT署名キー（ランダムな文字列を設定）
# 生成方法: openssl rand -hex 32
JWT_SECRET=jwt_secret_key_here

# バックエンドのポート
BACKEND_PORT=3000

# Node.js 環境（development / production）
NODE_ENV=development

# フロントエンドのURL（CORS設定用）
# Nginx経由でHTTPSアクセスする場合は https://localhost:8443
FRONTEND_URL=https://localhost:8443

# ----------------------------------------------
# フロントエンド設定（React + Vite）
# ----------------------------------------------
# バックエンドAPIのURL
# Nginx経由: https://localhost:8443/api
# 直接アクセス（開発時）: http://localhost:3000
VITE_API_URL=https://localhost:8443/api

# フロントエンドのポート
FRONTEND_PORT=3001

SKIP_AUTH=false

# ----------------------------------------------
# HashiCorp Vault 設定
# ----------------------------------------------
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=myroot

# backend/.env
FORTY_TWO_CLIENT_ID=your_42_client_id_here
FORTY_TWO_CLIENT_SECRET=your_42_client_secret_here
FORTY_TWO_CALLBACK_URL=https://localhost:8443/api/auth/42/callback

# ----------------------------------------------
# メール設定（GDPR通知メール用）
# ----------------------------------------------
# 未設定の場合、Etherealテストアカウントを自動生成してログにプレビューURLを表示する
# 本番SMTPを使う場合は以下を設定（例: Gmail）
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your-email@gmail.com
# MAIL_PASS=your-app-password
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=