{
	"name": "transcendence-backend",
	"version": "1.0.0",
	"description": "ft_transcendence backend",
	"scripts": {
		"start": "node dist/app/src/main",
		"start:dev": "nest start --watch --exec 'node dist/app/src/main'",
		"build": "nest build",
		"clean": "rm -rf dist && rm -f /shared/*.js /shared/*.d.ts /shared/*.map",
		"test": "ln -sf /app/node_modules /test/node_modules 2>/dev/null; vitest run",
		"migration:run": "typeorm migration:run -d dist/app/src/data-source.js",
		"migration:revert": "typeorm migration:revert -d dist/app/src/data-source.js",
		"migration:show": "typeorm migration:show -d dist/app/src/data-source.js",
		"migration:generate": "typeorm migration:generate -d dist/app/src/data-source.js"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.17",
		"@nestjs/core": "^11.1.17",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.17",
		"@nestjs/platform-socket.io": "^11.1.17",
		"@nestjs/typeorm": "^11.0.0",
		"@nestjs/websockets": "^11.1.17",
		"@types/cookie": "^0.6.0",
		"bcrypt": "^6.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.0",
		"cookie": "^1.1.1",
		"cookie-parser": "^1.4.7",
		"csrf-csrf": "^4.0.3",
		"express-session": "^1.17.3",
		"multer": "^2.0.2",
		"nodemailer": "^8.0.5",
		"passport": "^0.7.0",
		"passport-42": "^1.2.6",
		"passport-jwt": "^4.0.1",
		"pg": "^8.11.0",
		"qrcode": "^1.5.4",
		"reflect-metadata": "^0.1.13",
		"socket.io": "^4.8.3",
		"speakeasy": "^2.0.0",
		"typeorm": "^0.3.17"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.17",
		"@nestjs/schematics": "^11.0.10",
		"@nestjs/testing": "^11.0.0",
		"@swc/core": "^1.15.18",
		"@types/bcrypt": "^5.0.2",
		"@types/cookie-parser": "^1.4.8",
		"@types/express": "^4.17.17",
		"@types/express-session": "^1.17.7",
		"@types/multer": "^2.0.0",
		"@types/node": "^20.0.0",
		"@types/nodemailer": "^6.4.23",
		"@types/passport-42": "^1.1.0",
		"@types/passport-jwt": "^4.0.0",
		"@types/qrcode": "^1.5.6",
		"@types/socket.io": "^3.0.2",
		"@types/speakeasy": "^2.0.10",
		"@types/supertest": "^6.0.0",
		"socket.io-client": "^4.8.3",
		"supertest": "^6.3.0",
		"typescript": "^5.0.0",
		"unplugin-swc": "^1.5.9",
		"vitest": "^3.1.1"
	},
	"overrides": {
		"path-to-regexp": ">=8.4.2"
	}
}
